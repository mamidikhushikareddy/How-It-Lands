# ============================================================
# Environment configuration template.
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file — it is already in .gitignore.
# ============================================================

GEMINI_API_KEY=""
APP_URL="http://localhost:3000"
DATABASE_URL=""
VITE_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SIGNING_SECRET=""
WEBHOOK_SECRET=""

# SUPER_ADMIN_EMAIL: the single account allowed to add/remove admins
# and see the Admin Terminal. Defaults to kiaria2514@gmail.com if unset.
SUPER_ADMIN_EMAIL="kiaria2514@gmail.com"

# INTERNAL_CRON_SECRET: required to trigger the monthly report job at
# POST /api/internal/notifications/monthly-report (sent as the
# x-cron-secret header). Not a user-facing feature — this is what an
# external scheduler (Render Cron Job, GitHub Actions, etc.) uses to
# authenticate. Generate the same way as SIGNING_SECRET/WEBHOOK_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_CRON_SECRET=""
